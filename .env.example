# View https://docs.g0v0.top/lazer/reference/configurations.html for details.
HOST="0.0.0.0"
PORT=8000

MYSQL_HOST="localhost"
MYSQL_PORT=3306
MYSQL_DATABASE="osu_api"
MYSQL_USER="osu_api"
MYSQL_PASSWORD="password"
MYSQL_ROOT_PASSWORD="password"
REDIS_URL="redis://127.0.0.1:6379"

JWT_SECRET_KEY="your_jwt_secret_here"
SERVER_URL="http://localhost:8000"
SENTRY_DSN="https://public@sentry.example.com/"
SP_SENTRY_DSN="https://public@sentry.example.com/"

FETCHER_CLIENT_ID=""
FETCHER_CLIENT_SECRET=""
FETCHER_SCOPES="public"

ENABLE_EMAIL_VERIFICATION=false
ENABLE_TOTP_VERIFICATION=true
ENABLE_SESSION_VERIFICATION=false
ENABLE_MULTI_DEVICE_LOGIN=true
MAX_TOKENS_PER_CLIENT=10
DEVICE_TRUST_DURATION_DAYS=30

ENABLE_RX=true
ENABLE_AP=true
ENABLE_SUPPORTER_FOR_ALL_USERS=true
ENABLE_ALL_BEATMAP_PP=true
SEASONAL_BACKGROUNDS=["url1","url2","url3"]

# Somtum dual-bancho: accounts are created in bancho.py / the Somtum frontend
# (the single source of truth) and mirrored into lazer_users by DB triggers.
# Set to false to disable g0v0's own registration so user IDs only ever
# originate in one place. Leave true for a standalone g0v0 deployment.
ENABLE_USER_REGISTRATION=false

# Somtum dual-bancho READ-ONLY slice: ship lazer as login + own-profile reads
# first; disable score submission and the leaderboard/ranking surfaces until the
# unified score store exists. All default true (standalone g0v0 behaviour).
ENABLE_SCORE_SUBMISSION=true
ENABLE_BEATMAP_LEADERBOARD=true
ENABLE_GLOBAL_RANKINGS=true

OSU_WEB_CLIENT_SECRET="your_osu_web_client_secret_here"
CORS_URLS='[]'
FRONTEND_URL

SAVE_REPLAYS=true

# Somtum dual-bancho: import osu!stable (bancho.py) scores into lazer so shared
# accounts see Recent/Ranks/Most Played. Reads bancho's DB on the same MySQL server.
ENABLE_STABLE_SCORE_IMPORT=false
STABLE_IMPORT_INTERVAL_SECONDS=300
BANCHO_DATABASE=freedomdive_db
